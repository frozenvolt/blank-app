{
  "name": "Debian + Python + SSH + Vim",
  "image": "mcr.microsoft.com/devcontainers/base:debian",

  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.11"
    },
    "ghcr.io/devcontainers/features/sshd:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/vim:1": {
      "version": "latest"
    }
  },

  "forwardPorts": [22]
}
